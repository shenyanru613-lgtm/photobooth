# === Required ===
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# === Supabase (PostgreSQL) ===
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Server ===
PORT=3001
NODE_ENV=development

# === Image storage ===
# Local: images stored in ./uploads (default)
# Supabase Storage: set to 'supabase' if you configure Supabase bucket
STORAGE_BACKEND=local
STORAGE_BUCKET=generations

# === Render.com WebSocket support ===
# Don't set this locally; Render sets it automatically
# RENDER_EXTERNAL_URL=https://your-app.onrender.com
